@model AIPoweredSoftwareDevelopment.Models.TestCase

@{
    ViewData["Title"] = "Test Case Details";
}

<div class="container">
    <h1>Test Case Details</h1>
    
    <div class="card">
        <div class="card-body">
            <h5 class="card-title">@Model.TestName</h5>
            <p class="card-text"><strong>Project:</strong> @Model.Project.Name</p>
            <p class="card-text"><strong>Test Type:</strong> @Model.TestType</p>
            <p class="card-text"><strong>Status:</strong> <span class="badge bg-@(Model.Status == "Passed" ? "success" : Model.Status == "Failed" ? "danger" : "secondary")">@Model.Status</span></p>
            <p class="card-text"><strong>Generated At:</strong> @Model.GeneratedAt.ToString("yyyy-MM-dd HH:mm")</p>
            @if (Model.LastRunAt.HasValue)
            {
                <p class="card-text"><strong>Last Run:</strong> @Model.LastRunAt.Value.ToString("yyyy-MM-dd HH:mm")</p>
            }
            
            <h6 class="mt-3">Description:</h6>
            <div class="bg-light p-3">@Model.TestDescription</div>
            
            <h6 class="mt-3">AI Generated Code:</h6>
            <pre class="bg-light p-3"><code>@Model.AiGeneratedCode</code></pre>
        </div>
    </div>
    
    <div class="mt-3">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Edit</a>
        <a asp-action="Index" asp-route-projectId="@Model.ProjectId" class="btn btn-secondary">Back to List</a>
    </div>
</div>
