@model AIPoweredSoftwareDevelopment.Models.TestCase

@{
    ViewData["Title"] = "Delete Test Case";
}

<div class="container">
    <h1>Delete Test Case</h1>
    
    <h3>Are you sure you want to delete this?</h3>
    
    <div class="card">
        <div class="card-body">
            <h5 class="card-title">@Model.TestName</h5>
            <p class="card-text"><strong>Project:</strong> @Model.Project.Name</p>
            <p class="card-text"><strong>Test Type:</strong> @Model.TestType</p>
            <p class="card-text"><strong>Status:</strong> @Model.Status</p>
        </div>
    </div>
    
    <form asp-action="Delete" class="mt-3">
        <input type="hidden" asp-for="Id" />
        <input type="submit" value="Delete" class="btn btn-danger" />
        <a asp-action="Index" asp-route-projectId="@Model.ProjectId" class="btn btn-secondary">Back to List</a>
    </form>
</div>
