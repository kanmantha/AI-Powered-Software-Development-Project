@model AIPoweredSoftwareDevelopment.Models.Project

@{
    ViewData["Title"] = "Delete Project";
}

<div class="container">
    <h1>Delete Project</h1>
    
    <h3>Are you sure you want to delete this?</h3>
    
    <div class="card">
        <div class="card-body">
            <h5 class="card-title">@Model.Name</h5>
            <p class="card-text"><strong>Description:</strong> @Model.Description</p>
            <p class="card-text"><strong>Technology:</strong> @Model.Technology</p>
            <p class="card-text"><strong>Repository:</strong> @Model.RepositoryUrl</p>
        </div>
    </div>
    
    <form asp-action="Delete" class="mt-3">
        <input type="hidden" asp-for="Id" />
        <input type="submit" value="Delete" class="btn btn-danger" />
        <a asp-action="Index" class="btn btn-secondary">Back to List</a>
    </form>
</div>
