{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=AIPoweredSoftwareDevelopment.db"
  },
  
  // ============================================
  // HOW TO GET FREE API KEYS:
  // ============================================
  // 1. GITHUB COPILOT (FREE for individuals):
  //    - Go to: https://github.com/settings/copilot
  //    - Enable Copilot (Free tier available)
  //    - Create PAT: https://github.com/settings/tokens
  //    - Token starts with: ghp_
  //
  // 2. CURSOR AI (FREE tier):
  //    - Sign up: https://cursor.sh
  //    - Settings → API Keys
  //
  // 3. OPENAI (Free credits for new accounts):
  //    - Sign up: https://platform.openai.com/signup
  //    - Get key: https://platform.openai.com/api-keys
  //    - Key starts with: sk-
  //
  // 4. CLAUDE/ANTHROPIC (Free tier):
  //    - Sign up: https://console.anthropic.com
  //    - Create API key in console
  //
  // 5. AZURE DEVOPS (FREE tier):
  //    - Sign up: https://azure.microsoft.com/free
  //    - Create PAT in Azure DevOps settings
  // ============================================
  
  "OpenAI": {
    // Get from: https://platform.openai.com/api-keys
    "ApiKey": "" // Leave empty if not using
  },
  "Claude": {
    // Get from: https://console.anthropic.com
    "ApiKey": "" // Leave empty if not using
  },
  "GitHub": {
    // Get from: https://github.com/settings/tokens
    "CopilotToken": "" // Leave empty if not using
  },
  "Cursor": {
    // Get from: https://cursor.sh settings
    "ApiKey": "" // Leave empty if not using
  },
  "AzureDevOps": {
    // Get from Azure DevOps organization settings
    "Organization": "", // Your Azure DevOps organization name
    "PatToken": "" // Leave empty if not using
  }
}
