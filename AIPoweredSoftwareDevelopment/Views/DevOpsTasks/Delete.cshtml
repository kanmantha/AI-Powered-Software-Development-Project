@model AIPoweredSoftwareDevelopment.Models.DevOpsTask

@{
    ViewData["Title"] = "Delete DevOps Task";
}

<div class="container">
    <h1>Delete DevOps Task</h1>
    
    <h3>Are you sure you want to delete this?</h3>
    
    <div class="card">
        <div class="card-body">
            <h5 class="card-title">@Model.TaskName</h5>
            <p class="card-text"><strong>Project:</strong> @Model.Project?.Name</p>
            <p class="card-text"><strong>Task Type:</strong> @Model.TaskType</p>
            <p class="card-text"><strong>Status:</strong> @Model.Status</p>
        </div>
    </div>
    
    <form asp-action="Delete" class="mt-3">
        <input type="hidden" asp-for="Id" />
        <input type="submit" value="Delete" class="btn btn-danger" />
        <a asp-action="Index" asp-route-projectId="@Model.ProjectId" class="btn btn-secondary">Back to List</a>
    </form>
</div>
