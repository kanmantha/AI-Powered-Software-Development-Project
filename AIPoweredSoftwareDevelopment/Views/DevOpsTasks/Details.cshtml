@model AIPoweredSoftwareDevelopment.Models.DevOpsTask

@{
    ViewData["Title"] = "DevOps Task Details";
}

<div class="container">
    <h1>DevOps Task Details</h1>
    
    <div class="card">
        <div class="card-body">
            <h5 class="card-title">@Model.TaskName</h5>
            <p class="card-text"><strong>Project:</strong> @Model.Project?.Name</p>
            <p class="card-text"><strong>Task Type:</strong> @Model.TaskType</p>
            <p class="card-text"><strong>Status:</strong> <span class="badge bg-@(Model.Status == "Completed" ? "success" : Model.Status == "In Progress" ? "warning" : "secondary")">@Model.Status</span></p>
            <p class="card-text"><strong>Created At:</strong> @Model.CreatedAt.ToString("yyyy-MM-dd HH:mm")</p>
            @if (Model.CompletedAt.HasValue)
            {
                <p class="card-text"><strong>Completed At:</strong> @Model.CompletedAt.Value.ToString("yyyy-MM-dd HH:mm")</p>
            }
            
            <h6 class="mt-3">Description:</h6>
            <div class="bg-light p-3">@Model.Description</div>
            
            <h6 class="mt-3">AI Suggestion:</h6>
            <div class="bg-light p-3">@Model.AiSuggestion</div>
        </div>
    </div>
    
    <div class="mt-3">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Edit</a>
        <a asp-action="Index" asp-route-projectId="@Model.ProjectId" class="btn btn-secondary">Back to List</a>
    </div>
</div>
