@model AIPoweredSoftwareDevelopment.Models.ErrorViewModel

@{
    ViewData["Title"] = "Error";
}

<div class="container mt-5">
    <div class="row">
        <div class="col-md-8 offset-md-2">
            <div class="card border-danger">
                <div class="card-header bg-danger text-white">
                    <h4 class="card-title mb-0">
                        <i class="fas fa-exclamation-triangle"></i> An Error Occurred
                    </h4>
                </div>
                <div class="card-body">
                    <h5 class="card-title">@(Model?.Message ?? "An unexpected error occurred.")</h5>
                    
                    @if (Model?.ShowTechnicalDetails == true)
                    {
                        <div class="mt-3">
                            <p><strong>Error ID:</strong> @Model.ErrorId</p>
                            @if (!string.IsNullOrEmpty(Model.TechnicalDetails))
                            {
                                <div class="alert alert-secondary">
                                    <strong>Technical Details:</strong>
                                    <pre class="mt-2">@Model.TechnicalDetails</pre>
                                </div>
                            }
                        </div>
                    }
                    
                    <div class="mt-4">
                        <a asp-controller="Home" asp-action="Index" class="btn btn-primary">
                            <i class="fas fa-home"></i> Go to Home
                        </a>
                        <button onclick="history.back()" class="btn btn-secondary">
                            <i class="fas fa-arrow-left"></i> Go Back
                        </button>
                    </div>
                </div>
            </div>
            
            @if (Model?.ShowTechnicalDetails == true)
            {
                <div class="card mt-3">
                    <div class="card-body">
                        <p class="text-muted small">
                            If this error persists, please contact support with Error ID: @Model.ErrorId
                        </p>
                    </div>
                </div>
            }
        </div>
    </div>
</div>
