@model IEnumerable<AIPoweredSoftwareDevelopment.Models.CodeReview>

@{
    ViewData["Title"] = "Code Reviews";
    var projectId = ViewBag.ProjectId as int?;
    var projectName = ViewBag.ProjectName as string;
}

<div class="container">
    <h1>Code Reviews</h1>
    
    @if (!string.IsNullOrEmpty(projectName))
    {
        <h4>Project: @projectName</h4>
    }
    
    <p>
        @if (projectId.HasValue)
        {
            <a asp-action="Create" asp-route-projectId="@projectId" class="btn btn-primary">Create New Code Review</a>
            <a asp-controller="Projects" asp-action="Details" asp-route-id="@projectId" class="btn btn-secondary">Back to Project</a>
        }
        else
        {
            <a asp-action="Create" class="btn btn-primary">Create New Code Review</a>
        }
    </p>
    
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Title</th>
                <th>Project</th>
                <th>Review Type</th>
                <th>Severity</th>
                <th>Status</th>
                <th>Reviewed</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Title</td>
                    <td>@item.Project?.Name</td>
                    <td>@item.ReviewType</td>
                    <td><span class="badge bg-@(item.Severity == "Critical" ? "danger" : item.Severity == "High" ? "warning" : "info")">@item.Severity</span></td>
                    <td><span class="badge bg-@(item.Status == "Completed" ? "success" : "secondary")">@item.Status</span></td>
                    <td>@item.ReviewedAt.ToString("yyyy-MM-dd")</td>
                    <td>
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-info btn-sm">Details</a>
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm">Edit</a>
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
