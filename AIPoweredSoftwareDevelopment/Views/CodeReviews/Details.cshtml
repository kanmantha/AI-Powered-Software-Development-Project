@model AIPoweredSoftwareDevelopment.Models.CodeReview

@{
    ViewData["Title"] = "Code Review Details";
}

<div class="container">
    <h1>Code Review Details</h1>
    
    <div class="card">
        <div class="card-body">
            <h5 class="card-title">@Model.Title</h5>
            <p class="card-text"><strong>Project:</strong> @Model.Project?.Name</p>
            <p class="card-text"><strong>Review Type:</strong> @Model.ReviewType</p>
            <p class="card-text"><strong>Severity:</strong> <span class="badge bg-@(Model.Severity == "Critical" ? "danger" : Model.Severity == "High" ? "warning" : "info")">@Model.Severity</span></p>
            <p class="card-text"><strong>Status:</strong> <span class="badge bg-@(Model.Status == "Completed" ? "success" : "secondary")">@Model.Status</span></p>
            <p class="card-text"><strong>Reviewed At:</strong> @Model.ReviewedAt.ToString("yyyy-MM-dd HH:mm")</p>
            
            <h6 class="mt-3">Code Snippet:</h6>
            <pre class="bg-light p-3"><code>@Model.CodeSnippet</code></pre>
            
            <h6 class="mt-3">AI Review Result:</h6>
            <div class="bg-light p-3">@Model.AiReviewResult</div>
        </div>
    </div>
    
    <div class="mt-3">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Edit</a>
        <a asp-action="Index" asp-route-projectId="@Model.ProjectId" class="btn btn-secondary">Back to List</a>
    </div>
</div>
