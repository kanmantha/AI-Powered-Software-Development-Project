@model AIPoweredSoftwareDevelopment.Models.BugReport

@{
    ViewData["Title"] = "Bug Report Details";
}

<div class="container">
    <h1>Bug Report Details</h1>
    
    <div class="card">
        <div class="card-body">
            <h5 class="card-title">@Model.Title</h5>
            <p class="card-text"><strong>Project:</strong> @Model.Project?.Name</p>
            <p class="card-text"><strong>Severity:</strong> <span class="badge bg-@(Model.Severity == "Critical" ? "danger" : Model.Severity == "High" ? "warning" : "info")">@Model.Severity</span></p>
            <p class="card-text"><strong>Status:</strong> <span class="badge bg-@(Model.Status == "Resolved" ? "success" : "secondary")">@Model.Status</span></p>
            <p class="card-text"><strong>Detected At:</strong> @Model.DetectedAt.ToString("yyyy-MM-dd HH:mm")</p>
            @if (Model.ResolvedAt.HasValue)
            {
                <p class="card-text"><strong>Resolved At:</strong> @Model.ResolvedAt.Value.ToString("yyyy-MM-dd HH:mm")</p>
            }
            
            <h6 class="mt-3">Description:</h6>
            <div class="bg-light p-3">@Model.Description</div>
            
            <h6 class="mt-3">AI Detection Result:</h6>
            <div class="bg-light p-3">@Model.AiDetectionResult</div>
        </div>
    </div>
    
    <div class="mt-3">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Edit</a>
        <a asp-action="Index" asp-route-projectId="@Model.ProjectId" class="btn btn-secondary">Back to List</a>
    </div>
</div>
